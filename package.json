{
  "name": "officer-character",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run version.ts > src/version.json && tsc -b && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy": "bun run build && firebase deploy",
    "build-offline": "echo 'export const offline = true' > src/config.ts && bun run build && echo 'export const offline = false' > src/config.ts"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@mantine/core": "^7.17.4",
    "@mantine/dates": "^7.17.4",
    "@mantine/dropzone": "^7.17.4",
    "@mantine/hooks": "^7.17.4",
    "@mantine/modals": "^7.17.4",
    "@mantine/notifications": "^7.17.4",
    "@mantine/tiptap": "^7.17.4",
    "@myriaddreamin/typst-ts-web-compiler": "^0.5.4",
    "@myriaddreamin/typst.ts": "^0.5.4",
    "@tabler/icons-react": "^3.31.0",
    "@tiptap/extension-highlight": "^2.11.7",
    "@tiptap/extension-image": "^2.11.7",
    "@tiptap/extension-link": "^2.11.7",
    "@tiptap/extension-placeholder": "^2.11.7",
    "@tiptap/extension-table": "^2.11.7",
    "@tiptap/extension-table-cell": "^2.11.7",
    "@tiptap/extension-table-header": "^2.11.7",
    "@tiptap/extension-table-row": "^2.11.7",
    "@tiptap/extension-text-align": "^2.11.7",
    "@tiptap/extension-underline": "^2.11.7",
    "@tiptap/react": "^2.11.7",
    "@tiptap/starter-kit": "^2.11.7",
    "dayjs": "^1.11.13",
    "firebase": "^10.14.1",
    "jewish-date": "^2.0.20",
    "leaflet": "^1.9.4",
    "leaflet-image": "^0.4.0",
    "leaflet.bigimage": "^1.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.17",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react-swc": "^3.8.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.19",
    "firebase-tools": "^13.35.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.18",
    "vite-plugin-pwa": "^0.20.5",
    "vite-plugin-static-copy": "^1.0.6"
  },
  "prettier": {
    "semi": false
  }
}
